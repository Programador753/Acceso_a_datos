@model AntonioMVC.Models.Meal

@{
    ViewData["Title"] = "Detalle del Meal";
}

<h1>Detalle del Meal</h1>

<div class="card">
    <div class="card-header">
        <h2>@Model.Name</h2>
    </div>
    <div class="card-body">
        <div class="row">
            <div class="col-md-6">
                @if (!string.IsNullOrEmpty(Model.ThumbnailUrl))
                {
                    <img src="@Model.ThumbnailUrl" alt="@Model.Name" class="img-fluid rounded mb-3" />
                }
                else
                {
                    <img src="~/images/no-image.jpg" alt="Sin imagen" class="img-fluid rounded mb-3" />
                }
            </div>
            <div class="col-md-6">
                <h4>Instrucciones:</h4>
                <p class="text-justify">@Model.Instructions</p>

                <h4>Ingredientes:</h4>
                <ul class="list-group">
                    @if (Model.MealIngredients != null && Model.MealIngredients.Any())
                    {
                        @foreach (var mealIngredient in Model.MealIngredients)
                        {
                            <li class="list-group-item">@mealIngredient.Ingredient.Name</li>
                        }
                    }
                    else
                    {
                        <li class="list-group-item text-muted">Sin ingredientes</li>
                    }
                </ul>
            </div>
        </div>
    </div>
    <div class="card-footer">
        <a asp-action="Index" class="btn btn-secondary">Volver al listado</a>
        <a asp-action="Edit" asp-route-id="@Model.IdMeal" class="btn btn-warning">Editar</a>
        <a asp-action="Delete" asp-route-id="@Model.IdMeal" class="btn btn-danger">Eliminar</a>
    </div>
</div>